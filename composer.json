{
    "name": "stagemaster/manager",
    "description": "Talent Show Management System",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Brusegan Samuele",
            "email": "samuele@example.com"
        }
    ],
    "require": {
        "php": ">=8.2"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "squizlabs/php_codesniffer": "^3.8"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test-coverage": "phpunit --coverage-filter app --coverage-html coverage --coverage-text",
        "test-js": "jest",
        "test-js-coverage": "jest --coverage"
    }
}
